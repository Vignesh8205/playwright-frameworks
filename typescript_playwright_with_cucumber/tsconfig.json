{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020", "DOM"],
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "outDir": "./dist",
    "rootDir": "./",
    "types": ["node", "@cucumber/cucumber", "@playwright/test"],
    "allowSyntheticDefaultImports": true,
    "declaration": true,
    "sourceMap": true,
    "allowJs": true
  },
  "include": [
    "src/**/*.ts",
    "pages/**/*.ts",
    "utils/**/*.ts",
    "config/**/*.ts",
    "scripts/**/*.js",
    "cucumber.config.ts",
    "playwright.config.ts"
  ],
  "exclude": ["node_modules", "dist", "reports", "test-results"]
}
