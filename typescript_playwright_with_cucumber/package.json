{
  "name": "playwright-cucumber-bdd-framework",
  "version": "3.0.0",
  "description": "Playwright + Cucumber BDD Test Automation Framework",
  "scripts": {
    "test": "cross-env ENV=dev cucumber-js",
    "test:all": "cross-env ENV=dev cucumber-js",
    "test:qa": "cross-env ENV=qa cucumber-js",
    "test:smoke": "cross-env ENV=dev cucumber-js --tags '@smoke'",
    "test:regression": "cross-env ENV=dev cucumber-js --tags '@regression'",
    "test:critical": "cross-env ENV=dev cucumber-js --tags '@critical'",
    "test:e2e": "cross-env ENV=dev cucumber-js --tags '@e2e'",
    "test:footer": "cross-env ENV=dev cucumber-js --tags '@footer'",
    "test:booking": "cross-env ENV=dev cucumber-js --tags '@booking'",
    "test:oneway": "cross-env ENV=dev cucumber-js --tags '@booking and not @twoway'",
    "test:twoway": "cross-env ENV=dev cucumber-js --tags '@twoway'",
    "test:smoke:critical": "cross-env ENV=dev cucumber-js --tags '@smoke and @critical'",
    "test:parallel": "cross-env ENV=dev cucumber-js --parallel 4",
    "test:headed": "cross-env ENV=dev HEADLESS=false cucumber-js",
    "test:headed:smoke": "cross-env ENV=dev HEADLESS=false cucumber-js --tags '@smoke'",
    "test:headed:twoway": "cross-env ENV=dev HEADLESS=false cucumber-js --tags '@twoway'",
    "test:debug": "cross-env ENV=dev HEADLESS=false DEBUG=true cucumber-js",
    "test:debug:smoke": "cross-env ENV=dev HEADLESS=false DEBUG=true cucumber-js --tags '@smoke'",
    "test:debug:twoway": "cross-env ENV=dev HEADLESS=false DEBUG=true cucumber-js --tags '@twoway'",
    "test:firefox": "cross-env ENV=dev BROWSER=firefox cucumber-js",
    "test:webkit": "cross-env ENV=dev BROWSER=webkit cucumber-js",
    "test:report": "node scripts/generate-cucumber-report.js",
    "test:dryrun": "cucumber-js --dry-run",
    "test:tag": "cross-env ENV=dev cucumber-js --tags",
    "test:tag:headed": "cross-env ENV=dev HEADLESS=false cucumber-js --tags",
    "test:tag:debug": "cross-env ENV=dev HEADLESS=false DEBUG=true cucumber-js --tags",
    "test:tag:qa": "cross-env ENV=qa cucumber-js --tags",
    "test:tag:parallel": "cross-env ENV=dev cucumber-js --parallel 4 --tags",
    "test:ui:dev": "cross-env ENV=dev npx playwright test tests/ui",
    "test:ui:qa": "cross-env ENV=qa npx playwright test tests/ui",
    "generate:test-data": "node scripts/generate-test-data.js",
    "validate:test-data": "node -e \"const {DataUtils} = require('./utils/index'); console.log(DataUtils.validateTestDataFiles());\""
  },
  "dependencies": {
    "@cucumber/cucumber": "^10.3.1",
    "@cucumber/pretty-formatter": "^1.0.0",
    "@playwright/test": "^1.49.0",
    "typescript": "^5.6.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/node": "^24.9.2",
    "@types/xlsx": "^0.0.35",
    "cross-env": "^7.0.3",
    "cucumber-html-reporter": "^7.1.1",
    "multiple-cucumber-html-reporter": "^3.7.0",
    "ts-node": "^10.9.2"
  }
}
